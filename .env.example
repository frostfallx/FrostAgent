# 上游 API 端点 URL，支持 OpenAI 兼容服务
UPSTREAM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/

# 上游 API 认证密钥
UPSTREAM_API_KEY=sk-your-api-key-here

# 中间件监听的地址和端口
LISTEN_ADDR=:8080
WS_LISTEN_ADDR=:1234

# 系统提示词
SYSTEM_PROMPT=你是一个乐于助人的助手。

# 模型名称
MODEL_NAME=

# 视觉模型名称（留空则采用默认模型）
VISUAL_MODEL_NAME=
